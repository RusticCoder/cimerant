application {
  config {
//    prodDatabaseType mariadb
//    prodDatabaseType mssql
//    prodDatabaseType mysql
    prodDatabaseType postgresql
  }
  entities *
}

entity Attachment {
  file ImageBlob
  fileContentType String maxlength(255)
  name String required maxlength(255)
}

entity Comment {
  date Instant
  text String maxlength(255)
}

entity Label {
  label String required maxlength(255)
}

entity Project {
  name String maxlength(255)
}

entity Ticket {
  date Instant
  description String maxlength(255)
  dueDate LocalDate
  priority String maxlength(255)
  status String maxlength(255)
  title String required maxlength(255)
  type String maxlength(255)
}

relationship ManyToOne {
  Attachment to Ticket
  Comment to Comment
  Comment to JhiUser
  Ticket to JhiUser
  Ticket to Project
}

relationship ManyToMany {
  Label to Ticket
}
