application {
  config {
//    prodDatabaseType mariadb
//    prodDatabaseType mssql
//    prodDatabaseType mysql
    prodDatabaseType postgresql
  }
  entities *
}

entity Country {
  countryName String maxlength(255)
}

entity Department {
  departmentName String required maxlength(255)
}

entity Employee {
  commissionPct Long maxlength(20)
  email String maxlength(255)
  firstName String maxlength(255)
  hireDate Instant maxlength(6)
  lastName String maxlength(255)
  phoneNumber String maxlength(255)
  salary Long maxlength(20)
}

entity Job {
  jobTitle String maxlength(255)
  maxSalary Long maxlength(20)
  minSalary Long maxlength(20)
}

entity JobHistory {
  endDate Instant maxlength(6)
  language String maxlength(255)
  startDate Instant maxlength(6)
}

entity Location {
  city String maxlength(255)
  postalCode String maxlength(255)
  stateProvince String maxlength(255)
  streetAddress String maxlength(255)
}

entity Region {
  regionName String maxlength(255)
}

entity Task {
  description String maxlength(255)
  title String maxlength(255)
}

relationship OneToOne {
  Country to Region
  Department to Location
  JobHistory to Department
  JobHistory to Employee
  JobHistory to Job
  Location to Country
}

relationship ManyToOne {
  Employee to Department
  Employee to Employee
  Job to Employee
}

relationship ManyToMany {
  Job to Job
  Job to Task
}
